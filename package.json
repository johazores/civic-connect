{
  "name": "civic-connect-multitenant",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "verify": "npm run lint && npm run typecheck && npm run build",
    "postinstall": "node scripts/prisma-generate.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma db push --force-reset && tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "vercel-build": "node scripts/prisma-generate.js && next build"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "@stellar/stellar-sdk": "^16.0.1",
    "@types/qrcode": "^1.5.5",
    "bcryptjs": "2.4.3",
    "jsonwebtoken": "9.0.3",
    "next": "16.2.10",
    "qrcode": "^1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-icons": "^5.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.2",
    "@types/bcryptjs": "2.4.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "22.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.2",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "postcss": "8.5.16",
    "prisma": "6.19.3",
    "tailwindcss": "4.3.2",
    "tsx": "4.22.4",
    "typescript": "5.9.3"
  }
}
