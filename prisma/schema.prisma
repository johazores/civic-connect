generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
}

enum ReportStatus {
  SUBMITTED
  REVIEWING
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  REJECTED
}

enum ReportPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Tenant {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  cityName    String
  tagline     String
  description String
  address     String?
  email       String?
  phone       String?
  primaryColor String  @default("#0f766e")
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  citizens    Citizen[]
  departments Department[]
  categories  ReportCategory[]
  reports     Report[]
  services    Service[]
  hotlines    Hotline[]
  newsPosts   NewsPost[]
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  email        String
  passwordHash String
  role         UserRole @default(STAFF)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reportUpdates ReportUpdate[]

  @@unique([tenantId, email])
  @@index([tenantId])
}


model Citizen {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  email        String
  phone        String?
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reports Report[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Department {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  email     String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reports   Report[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model ReportCategory {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reports     Report[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Report {
  id            String         @id @default(cuid())
  tenantId      String
  categoryId    String
  departmentId  String?
  citizenId     String?
  referenceCode String         @unique
  reporterName  String
  reporterEmail String?
  reporterPhone String?
  title         String
  description   String
  locationText  String
  latitude      Float?
  longitude     Float?
  status        ReportStatus   @default(SUBMITTED)
  priority      ReportPriority @default(NORMAL)
  submittedAt   DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category     ReportCategory @relation(fields: [categoryId], references: [id])
  department   Department?    @relation(fields: [departmentId], references: [id])
  citizen      Citizen?       @relation(fields: [citizenId], references: [id], onDelete: SetNull)
  updates      ReportUpdate[]
  attachments  ReportAttachment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, citizenId])
  @@index([tenantId, submittedAt])
}

model ReportUpdate {
  id        String       @id @default(cuid())
  reportId  String
  userId    String?
  status    ReportStatus
  message   String
  isPublic  Boolean      @default(true)
  createdAt DateTime     @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([reportId])
}

model ReportAttachment {
  id        String   @id @default(cuid())
  reportId  String
  imageUrl  String
  caption   String?
  createdAt DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
}

model Service {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  description String
  department  String?
  linkUrl     String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Hotline {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  phone       String
  isEmergency Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model NewsPost {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  excerpt     String
  content     String
  imageUrl    String?
  isPublished Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, publishedAt])
}
