generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
}

model PlatformAdmin {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum ReportStatus {
  SUBMITTED
  REVIEWING
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  REJECTED
}

enum ReportPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum PaymentStatus {
  PENDING
  VERIFIED
  FAILED
  CANCELLED
  EXPIRED
}

enum StellarWalletStatus {
  NOT_CONFIGURED
  GENERATED
  IMPORTED
  FUNDED
  ACTIVE
  ERROR
}


enum CivicActionType {
  PARTICIPATION
  CLEANUP
}

enum CivicActionStatus {
  SUBMITTED
  REVIEWING
  APPROVED
  REJECTED
  REWARDED
}

enum TransparencyEntryType {
  BUDGET_ALLOCATION
  PUBLIC_DISBURSEMENT
  PROCUREMENT
  GRANT
  OPERATING_EXPENSE
}

enum TransparencyEntryStatus {
  DRAFT
  PUBLISHED
  VERIFIED_ON_STELLAR
  ARCHIVED
}

enum PropertyTaxReceiptStatus {
  DRAFT
  ISSUED
  VOID
}

enum RewardPayoutMethod {
  DIRECT
  CLAIMABLE
}

model Tenant {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  cityName    String
  tagline     String
  description String
  address     String?
  email       String?
  phone       String?
  primaryColor String  @default("#1f6feb")
  stellarReceivingPublicKey String?
  stellarReceivingSecretEncrypted String?
  stellarNetwork String @default("TESTNET")
  stellarNetworkPassphrase String @default("Test SDF Network ; September 2015")
  stellarHorizonUrl String @default("https://horizon-testnet.stellar.org")
  stellarFriendbotUrl String @default("https://friendbot.stellar.org")
  stellarDefaultAssetCode String @default("XLM")
  stellarDefaultAssetIssuer String?
  stellarWalletStatus StellarWalletStatus @default(NOT_CONFIGURED)
  stellarWalletLastCheckedAt DateTime?
  stellarWalletLastFundedAt DateTime?
  stellarWalletError String?
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  citizens    Citizen[]
  departments Department[]
  categories  ReportCategory[]
  reports     Report[]
  services    Service[]
  hotlines    Hotline[]
  newsPosts   NewsPost[]
  paymentIntents PaymentIntent[]
  civicActions CivicAction[]
  transparencyEntries TransparencyEntry[]
  propertyTaxReceipts PropertyTaxReceipt[]
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  email        String
  passwordHash String
  role         UserRole @default(STAFF)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reportUpdates ReportUpdate[]

  @@unique([tenantId, email])
  @@index([tenantId])
}


model Citizen {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  email        String
  phone        String?
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reports Report[]
  paymentIntents PaymentIntent[]
  civicActions CivicAction[]
  propertyTaxReceipts PropertyTaxReceipt[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Department {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  email     String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reports   Report[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model ReportCategory {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reports     Report[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Report {
  id            String         @id @default(cuid())
  tenantId      String
  categoryId    String
  departmentId  String?
  citizenId     String?
  referenceCode String         @unique
  reporterName  String
  reporterEmail String?
  reporterPhone String?
  title         String
  description   String
  locationText  String
  latitude      Float?
  longitude     Float?
  status        ReportStatus   @default(SUBMITTED)
  priority      ReportPriority @default(NORMAL)
  submittedAt   DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category     ReportCategory @relation(fields: [categoryId], references: [id])
  department   Department?    @relation(fields: [departmentId], references: [id])
  citizen      Citizen?       @relation(fields: [citizenId], references: [id], onDelete: SetNull)
  updates      ReportUpdate[]
  attachments  ReportAttachment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, citizenId])
  @@index([tenantId, submittedAt])
}

model ReportUpdate {
  id        String       @id @default(cuid())
  reportId  String
  userId    String?
  status    ReportStatus
  message   String
  isPublic  Boolean      @default(true)
  createdAt DateTime     @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([reportId])
}

model ReportAttachment {
  id        String   @id @default(cuid())
  reportId  String
  imageUrl  String
  caption   String?
  createdAt DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
}

model Service {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  description String
  department  String?
  linkUrl     String?
  paymentRequired Boolean @default(false)
  feeAmount Decimal? @db.Decimal(12, 7)
  feeAssetCode String @default("XLM")
  feeAssetIssuer String?
  receivingPublicKey String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  paymentIntents PaymentIntent[]

  @@index([tenantId])
}

model PaymentIntent {
  id String @id @default(cuid())
  tenantId String
  citizenId String?
  serviceId String
  referenceCode String @unique
  payerName String
  payerEmail String?
  payerPhone String?
  amount Decimal @db.Decimal(12, 7)
  assetCode String @default("XLM")
  assetIssuer String?
  destinationPublicKey String
  memo String
  sep7Uri String
  status PaymentStatus @default(PENDING)
  transactionHash String? @unique
  paymentOperationId String? @unique
  payerPublicKey String?
  ledger Int?
  failureReason String?
  lastSubmittedTransactionHash String?
  verificationAttempts Int @default(0)
  lastVerificationAt DateTime?
  paidAt DateTime?
  verifiedAt DateTime?
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  citizen Citizen? @relation(fields: [citizenId], references: [id], onDelete: SetNull)
  service Service @relation(fields: [serviceId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, serviceId])
  @@index([tenantId, createdAt])
}


model CivicAction {
  id String @id @default(cuid())
  tenantId String
  citizenId String?
  type CivicActionType @default(PARTICIPATION)
  title String
  description String
  locationText String
  latitude Float?
  longitude Float?
  photoUrl String?
  participantName String
  participantEmail String?
  participantPhone String?
  rewardDestinationPublicKey String?
  rewardAmount Decimal @default(0) @db.Decimal(12, 7)
  rewardAssetCode String @default("XLM")
  rewardAssetIssuer String?
  rewardMemo String?
  status CivicActionStatus @default(SUBMITTED)
  verificationNote String?
  proofDigest String?
  payoutMethod RewardPayoutMethod @default(DIRECT)
  rewardTransactionHash String? @unique
  rewardOperationId String? @unique
  rewardClaimableBalanceId String?
  rewardLedger Int?
  rewardPaidAt DateTime?
  reviewedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  citizen Citizen? @relation(fields: [citizenId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([tenantId, createdAt])
}

model TransparencyEntry {
  id String @id @default(cuid())
  tenantId String
  referenceCode String @unique
  entryType TransparencyEntryType @default(PUBLIC_DISBURSEMENT)
  status TransparencyEntryStatus @default(PUBLISHED)
  title String
  description String
  department String?
  recipientName String?
  recipientPublicKey String?
  amount Decimal @db.Decimal(14, 7)
  assetCode String @default("XLM")
  assetIssuer String?
  memo String?
  proofDigest String?
  transactionHash String? @unique
  paymentOperationId String? @unique
  ledger Int?
  occurredAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, entryType])
  @@index([tenantId, occurredAt])
}

model PropertyTaxReceipt {
  id String @id @default(cuid())
  tenantId String
  citizenId String?
  referenceCode String @unique
  taxpayerName String
  taxpayerEmail String?
  propertyIndexNumber String
  propertyAddress String
  taxYear Int
  amount Decimal @db.Decimal(14, 7)
  assetCode String @default("XLM")
  assetIssuer String?
  proofDigest String?
  paymentIntentId String?
  transactionHash String? @unique
  ledger Int?
  status PropertyTaxReceiptStatus @default(ISSUED)
  issuedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  citizen Citizen? @relation(fields: [citizenId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, taxpayerEmail])
  @@index([tenantId, propertyIndexNumber])
  @@index([tenantId, taxYear])
}

model Hotline {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  phone       String
  isEmergency Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model NewsPost {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  excerpt     String
  content     String
  imageUrl    String?
  isPublished Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, publishedAt])
}
